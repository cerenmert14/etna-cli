{
    "check_steps": [
        {
            "Command": {
                "command": "dune",
                "args": [
                    "--version"
                ]
            }
        },
        {
            "Command": {
                "command": "opam",
                "args": [
                    "--version"
                ]
            }
        }
    ],
    "build_steps": [
        {
            "Command": {
                "command": "opam",
