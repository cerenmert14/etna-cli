{
    "name": "Rust",
    "check_steps": [],
    "build_steps": [
        {
            "Command": {
                "command": "cargo",
                "args": [
                    "build",
                    "--release"
                ]
            }
        }
    ],
    "run_step": {
        "Command": {
            "command": "$workload_path/target/release/rbt",
            "args": [
                "$property",
                "$strategy"
            ],
            "params": [
                "workload_path",
                "property",
                "strategy"
            ]
        }
    }
}