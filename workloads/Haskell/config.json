{
    "check_steps": [],
    "build_steps": [
        {
            "Command": {
                "command": "stack",
                "args": [
                    "build"
                ]
            }
        }
    ],
    "run_step": {
        "Match": {
            "value": "cross",
            "options": {
                "true": {
                    "Command": {
                        "command": "$workload_path/target/release/bst-sampler",
                        "args": [
                            "$strategy",
                            "$property"
                        ],
                        "params": [
                            "workload_path",
                            "property",
                            "strategy"
                        ]
                    }
                },
                "false": {
                    "Command": {
                        "command": "stack",
                        "args": [
                            "exec",
                            "etna-workload",
                            "--",
                            "{\"workload\": \"$workload\", \"strategy\": \"$strategy\", \"property\": \"prop_$property\", \"timeout\": $timeout}"
                        ],
                        "params": [
                            "workload",
                            "timeout",
                            "workload_path",
                            "property",
                            "strategy"
                        ]
                    }
                }
            }
        }
    }
}