{
  "setup_steps": [],
  "build_steps": [
    {
      "Command": {
        "command": "cargo",
        "args": [
          "build",
          "--release"
        ]
      }
    }
  ],
  "test_steps": [
    {
      "Match": {
        "value": "cross",
        "options": {
          "true": {
            "Command": {
              "command": "$workload_path/target/release/stlc-sampler",
              "args": [
                "$strategy",
                "$property",
                "$tests"
              ],
              "params": [
                "workload_path",
                "property",
                "strategy"
              ]
            }
          },
          "false": {
            "Command": {
              "command": "$workload_path/target/release/stlc",
              "args": [
                "$strategy",
                "$property"
              ],
              "params": [
                "workload_path",
                "property",
                "strategy"
              ]
            }
          }
        }
      }
    }
  ]
}
