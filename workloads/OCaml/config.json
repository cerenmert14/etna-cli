                ]
            }
        },
        {
            "Command": {
                "command": "opam",
                "args": [
                    "exec",
                    "--",
                    "dune",
                    "build"
                ]
            }
        }
    ],
    "run_step": {
        "Command": {
            "run_at": "/Users/nikhil/Code/etna-cli/exp1/workloads/OCaml/BST",
            "command": "opam",
            "args": [
                "exec",
                "--",
                "dune",
                "exec",
                "BST",
