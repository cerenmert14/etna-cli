{
    "check_steps": [],
    "build_steps": [],
    "run_step": {
        "Match": {
            "value": "cross",
            "options": {
                "false": {
                    "Command": {
                        "command": "uv",
                        "args": [
                            "run",
                            "main.py",
                            "quickcheck",
                            "$property"
                        ],
                        "run_at": "$workload_path"
                    }
                },
                "true": {
                    "Command": {
                        "command": "uv",
                        "args": [
                            "run",
                            "main-sampler.py",
                            "$property",
                            "$tests"
                        ],
                        "run_at": "$workload_path"
                    }
                }
            }
        }
    }
}
